# --- Core ---
DATABASE_URL=postgresql://user:password@localhost:5432/elite_erp
# Required. Signs session JWTs. Generate with: openssl rand -hex 32
AUTH_SECRET=replace-with-a-long-random-string

# --- Stage 11: field-level encryption (Part 2) ---
# Comma-separated list of "version:base64-32byte-key". First entry is the current
# write key; keep older versions to decrypt data written before a rotation.
# Generate a key with: node -e "console.log('1:'+require('crypto').randomBytes(32).toString('base64'))"
FIELD_ENCRYPTION_KEYS=1:replace-with-a-base64-encoded-32-byte-key
